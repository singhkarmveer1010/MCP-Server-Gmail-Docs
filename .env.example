# Google OAuth (required for server runtime)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Prefer this on Railway (ephemeral disk — do not rely on tokens.json alone)
GOOGLE_REFRESH_TOKEN=

# Where OAuth tokens are stored locally (optional if GOOGLE_REFRESH_TOKEN is set)
GOOGLE_TOKEN_STORAGE_PATH=./tokens.json

# Desktop OAuth client redirect (local get-refresh-token only)
GOOGLE_REDIRECT_URI=http://localhost:3000/

# Optional logging: info | debug | warn | error
LOG_LEVEL=info

# Transport: leave unset to auto-detect (PORT set → HTTP; otherwise stdio)
# MCP_TRANSPORT=http
# MCP_TRANSPORT=stdio

# Shared secret for HTTP /mcp (recommended on Railway). Send as:
#   Authorization: Bearer <token>
# MCP_AUTH_TOKEN=

# Integration / smoke tests (optional)
# RUN_INTEGRATION=1
# TEST_EMAIL_TO=you@example.com
# TEST_DOCUMENT_ID=
