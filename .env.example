# Google OAuth (required for server runtime)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Where OAuth tokens are stored (written by npm run get-refresh-token; read by the server)
GOOGLE_TOKEN_STORAGE_PATH=./tokens.json

# Desktop OAuth client redirect (must match Google Cloud / client_secret JSON)
GOOGLE_REDIRECT_URI=http://localhost:3000/

# Optional logging: info | debug | warn | error
LOG_LEVEL=info

# Integration / smoke tests (optional)
# RUN_INTEGRATION=1
# TEST_EMAIL_TO=you@example.com
# TEST_DOCUMENT_ID=
